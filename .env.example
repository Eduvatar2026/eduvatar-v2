# ============================================
# Victory Learning Platform - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# DeepSeek API (Required for AI Chatbot)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Supabase (Required for database & auth)
# Get these at: https://supabase.com → New Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional: Google Translate API for multilingual support
# GOOGLE_TRANSLATE_API_KEY=your_google_translate_key
